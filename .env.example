# LexSeek Docker 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ==================== 数据库配置 ====================
# PostgreSQL 连接字符串（必填）
DATABASE_URL=postgresql://user:password@host:5432/lexseek

# ==================== JWT 配置 ====================
NUXT_JWT_SECRET=your_jwt_secret_here
NUXT_JWT_EXPIRES_IN=30d

# ==================== 认证配置 ====================
NUXT_AUTH_COOKIE_NAME=auth_token
NUXT_AUTH_COOKIE_MAX_AGE=2592000

# ==================== 阿里云基础配置 ====================
NUXT_ALIYUN_ACCESS_KEY_ID=
NUXT_ALIYUN_ACCESS_KEY_SECRET=

# ==================== 阿里云短信配置 ====================
NUXT_ALIYUN_SMS_ENABLE=false
NUXT_ALIYUN_SMS_SIGN_NAME=
NUXT_ALIYUN_SMS_TEMPLATE_CAPTCHA_CODE=
NUXT_ALIYUN_SMS_RATE_LIMIT_MS=60
NUXT_ALIYUN_SMS_CODE_EXPIRE_MS=300
NUXT_ALIYUN_SMS_MAX_FAILURES=5
NUXT_ALIYUN_SMS_LOCK_DURATION_MS=900


# ==================== 存储配置 ====================
# 存储类型: aliyun_oss, qiniu, tencent_cos
NUXT_STORAGE_DEFAULT_TYPE=aliyun_oss
# OSS 回调 URL
NUXT_STORAGE_CALLBACK_URL=
# 文件存储基础路径
NUXT_STORAGE_BASE_PATH=

# ==================== 阿里云 OSS 配置 ====================
NUXT_STORAGE_ALIYUN_OSS_ACCESS_KEY_ID=
NUXT_STORAGE_ALIYUN_OSS_ACCESS_KEY_SECRET=
NUXT_STORAGE_ALIYUN_OSS_BUCKET=
NUXT_STORAGE_ALIYUN_OSS_REGION=oss-cn-hangzhou
NUXT_STORAGE_ALIYUN_OSS_CUSTOM_DOMAIN=
# 阿里云 OSS STS 配置（可选，用于临时凭证）
NUXT_STORAGE_ALIYUN_OSS_STS_ROLE_ARN=
NUXT_STORAGE_ALIYUN_OSS_STS_ROLE_SESSION_NAME=
NUXT_STORAGE_ALIYUN_OSS_STS_DURATION_SECONDS=

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARN, ERROR, SILENT
NUXT_PUBLIC_LOG_LEVEL=INFO

# ==================== 应用配置 ====================
# 应用基础 URL（用于支付回调等，必须是 HTTPS）
NUXT_PUBLIC_BASE_URL=https://your-domain.com

# ==================== 微信公众号配置 ====================
# 微信公众号 AppID（前端 OAuth 授权 + 后端支付共用）
NUXT_PUBLIC_WECHAT_APP_ID=你的公众号AppID
# 微信公众号 AppSecret（用于 OAuth 获取 OpenID）
NUXT_WECHAT_MP_SECRET=你的公众号AppSecret
# 通用授权回调地址（配置在微信公众号后台，支持多环境共用）
NUXT_PUBLIC_WECHAT_AUTH_CALLBACK_URL=https://your-domain.com/api/v1/wechat/auth-callback
# 授权回调重定向白名单（逗号分隔，安全限制）
NUXT_WECHAT_AUTH_REDIRECT_WHITELIST=https://your-domain.com,http://localhost:3000

# ==================== 微信支付配置 ====================
# 微信支付商户号
NUXT_WECHAT_PAY_MCH_ID=你的商户号
# API v3 密钥
NUXT_WECHAT_PAY_API_V3_KEY=你的APIv3密钥
# 商户证书序列号
NUXT_WECHAT_PAY_SERIAL_NO=你的商户证书序列号
# 商户私钥（PEM 格式）
NUXT_WECHAT_PAY_PRIVATE_KEY=你的商户私钥
# 微信支付回调通知地址（必须是 HTTPS）
NUXT_WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/v1/payments/callback/wechat
# 微信平台证书（可选，用于验证回调签名）
# NUXT_WECHAT_PAY_PLATFORM_CERT=


# ==================== 向量模型配置（保底策略） ====================
NUXT_EMBEDDING_API_KEY=向量模型API密钥
NUXT_EMBEDDING_BASE_URL=向量模型基础URL
NUXT_EMBEDDING_MODEL=向量模型名称

# ==================== Agent 后台任务队列 ====================
NUXT_REDIS_URL=redis://localhost:6379
NUXT_AGENT_DATABASE_URL=                     # Agent 专用数据库连接，默认回退到 DATABASE_URL
NUXT_AGENT_MAX_CONCURRENT=3                  # 单实例最大并发 Agent 数
NUXT_AGENT_MAX_USER_CONCURRENT=2             # 单用户最大并发（跨 session）
NUXT_AGENT_TIMEOUT_MS=3600000                # Agent 执行超时（1小时）
NUXT_AGENT_HEARTBEAT_INTERVAL_MS=15000       # 心跳间隔
NUXT_AGENT_CRASH_THRESHOLD_MS=60000          # 心跳超时判定崩溃
NUXT_AGENT_PENDING_QUEUE_MAX=500000          # 最大队列长度

# ==================== Rerank 配置 ====================
NUXT_RERANK_API_KEY=
NUXT_RERANK_BASE_URL=
NUXT_RERANK_MODEL=gte-rerank-v2

# 检索阈值
NUXT_LAW_RERANK_THRESHOLD=0.3
NUXT_MATERIAL_RERANK_THRESHOLD=0.2

# HNSW 搜索参数
NUXT_HNSW_EF_SEARCH=100

# ==================== bge-reranker TEI 服务 ====================
# bge-reranker-v2-m3 HTTP 服务 URL（M3 记忆召回）
RERANKER_URL=http://localhost:8090


# 评测环境变量
EVAL_DEEPSEEK_KEY= # DeepSeek apikey
REDIS_PASSWORD=  # 如果你的本地 Redis 有密码

# ==================== Langfuse 可观测性（自托管 https://langfuse.lexseek.cn）====================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://langfuse.lexseek.cn
LANGFUSE_TRACING_ENABLED=true
LANGFUSE_MASK_PII=true
LANGFUSE_ENVIRONMENT=development
