  markdownContent String?   @map("markdown_content") @db.Text
  /// 关键词
  keywords        Json?     @map("keywords")
  /// 摘要
  summary         String?   @map("summary")
  /// 向量存储的ID集合
  vectorIds       Json?     @map("vector_ids")
  /// 最后嵌入时间
  lastEmbeddingAt DateTime? @map("last_embedding_at") @db.Timestamptz(6)
  /// 最后编辑时间
  lastEditAt      DateTime? @map("last_edit_at") @db.Timestamptz()
  /// 创建时间
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为NULL表示未删除
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)
  ossFile         ossFiles  @relation(fields: [ossFileId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user            users     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([ossFileId], map: "idx_image_recognition_records_oss_file_id")
  @@index([userId], map: "idx_image_recognition_records_user_id")
  @@index([imageType], map: "idx_image_recognition_records_image_type")
  @@index([status], map: "idx_image_recognition_records_status")
  @@index([lastEmbeddingAt], map: "idx_image_recognition_records_last_embedding_at")
  @@index([lastEditAt], map: "idx_image_recognition_records_last_edit_at")
  @@index([deletedAt], map: "idx_image_recognition_records_deleted_at")
  @@map("image_recognition_records")
}

/// 会员升级记录表
model membershipUpgradeRecords {
  /// 升级记录ID，主键，自增
  id                    Int              @id @default(autoincrement())
  /// 用户ID
  userId                Int              @map("user_id")
  /// 原会员记录ID
  fromMembershipId      Int              @map("from_membership_id")
  /// 新会员记录ID
  toMembershipId        Int?             @map("to_membership_id")
  /// 原会员级别ID
  fromLevelId           Int              @map("from_level_id")
  /// 目标会员级别ID
  toLevelId             Int              @map("to_level_id")
  /// 升级价格
  upgradePrice          Decimal          @map("upgrade_price") @db.Decimal(10, 2)
  /// 原会员剩余天数
  originalRemainingDays Int              @map("original_remaining_days")
  /// 积分补偿
  pointCompensation     Int?             @default(0) @map("point_compensation")
  /// 关联的支付订单ID
  paymentOrderId        Int?             @map("payment_order_id")
  /// 状态：0-失败，1-成功，2-待支付
  status                Int?             @default(1)
  /// 创建时间
  createdAt             DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 更新时间
  updatedAt             DateTime?        @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间
  deletedAt             DateTime?        @map("deleted_at") @db.Timestamptz(6)
  toMembership          userMemberships? @relation("ToMembership", fields: [toMembershipId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "membershipUpgradeRecords_toMembershipId_fkey")
  fromLevel             membershipLevels @relation("FromLevel", fields: [fromLevelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fromMembership        userMemberships  @relation("FromMembership", fields: [fromMembershipId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paymentOrder          paymentOrders?   @relation(fields: [paymentOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  toLevel               membershipLevels @relation("ToLevel", fields: [toLevelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                  users            @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId], map: "idx_membership_upgrade_records_user_id")
  @@index([status], map: "idx_membership_upgrade_records_status")
  @@index([createdAt], map: "idx_membership_upgrade_records_created_at")
  @@index([fromMembershipId], map: "idx_membership_upgrade_records_from_membership_id")
  @@index([toMembershipId], map: "idx_membership_upgrade_records_to_membership_id")
  @@map("membership_upgrade_records")
}

/// 法条内容嵌入表
model lawEmbeddings {
  /// 主键
  id        String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// 法律内容
  text      String?
  /// 法律内容元数据
  metadata  Json?
  /// 法律内容嵌入
  embedding Unsupported("vector")?

  @@map("law_embeddings")
}
