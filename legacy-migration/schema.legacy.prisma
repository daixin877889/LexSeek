generator client {
  provider = "prisma-client"
  output   = "./legacy-client"
}

// generator comments {
//   provider = "prisma-db-comments-generator"
// }

datasource db {
  provider = "postgresql"
  // 连接池配置，在连接字符串中可以添加参数来控制连接池
  // 例如：postgresql://user:password@localhost:5432/db?connection_limit=20&pool_timeout=20
  // 注意：Prisma 7 中，连接 URL 需要在 prisma.config.ts 中配置（用于迁移）和 PrismaClient 构造函数中传递（用于运行时）
}

/// 用户表
model users {
  /// 用户ID，主键，自增
  id                       Int                        @id @default(autoincrement())
  /// 用户姓名
  name                     String                     @db.VarChar(100)
  /// 用户名，可选
  username                 String?                    @db.VarChar(100)
  /// 电子邮箱，可选
  email                    String?                    @db.VarChar(100)
  /// 手机号，唯一标识
  phone                    String                     @unique @db.VarChar(11)
  /// 密码，加密存储
  password                 String?                    @db.VarChar(100)
  /// 用户角色：user-普通用户，admin-管理员
  role                     String                     @default("user") @db.VarChar(20)
  /// 用户状态：1-启用，0-禁用
  status                   Int                        @default(1)
  /// 所属公司/律所，可选
  company                  String?                    @db.VarChar(100)
  /// 个人简介，可选
  profile                  String?
  /// 邀请码，唯一
  inviteCode               String                     @unique @map("invite_code") @db.VarChar(10)
  /// 邀请人用户ID，外键关联用户表
  invitedBy                Int?                       @map("invited_by")
  /// 微信小程序openid
  openid                   String?                    @map("openid") @db.VarChar(100)
  /// 微信小程序unionid
  unionid                  String?                    @map("unionid") @db.VarChar(100)
  /// 用户注册渠道
  registerChannel          String?                    @map("register_channel") @db.VarChar(100)
  /// API Key
  apiKey                   String?                    @unique @default(dbgenerated("gen_random_uuid()")) @map("api_key") @db.Uuid
  /// 创建时间
  createdAt                DateTime?                  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt                DateTime?                  @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间
  deletedAt                DateTime?                  @map("deleted_at") @db.Timestamptz(6)
  asrRecords               asrRecords[]
  caseAnalyses             caseAnalyses[]
  caseMaterials            caseMaterials[]
  cases                    cases[]
  docRecognitionRecords    docRecognitionRecords[]
  membershipUpgradeRecords membershipUpgradeRecords[]
  paymentOrders            paymentOrders[]
  pointConsumptionRecords  pointConsumptionRecords[]
  pointRecords             pointRecords[]
  redemptionCodes          redemptionCodes[]
  redemptionRecords        redemptionRecords[]
  userMemberships          userMemberships[]
  imageRecognitionRecords  imageRecognitionRecords[]

  @@index([status], map: "idx_users_status")
  @@index([deletedAt], map: "idx_users_deleted_at")
  @@index([role], map: "idx_users_role")
  @@map("users")
}

/// 会员级别表
model membershipLevels {
  /// 会员级别ID，主键，自增
  id                 Int                        @id @default(autoincrement())
  /// 会员级别名称
  name               String                     @db.VarChar(100)
  /// 会员级别描述
  description        String?
  /// 月度价格（元）- 已废弃，使用 products 表中的价格
  priceMonthly       Decimal?                   @map("price_monthly") @db.Decimal(10, 2)
  /// 年度价格（元）- 已废弃，使用 products 表中的价格
  priceYearly        Decimal?                   @map("price_yearly") @db.Decimal(10, 2)
  /// 赠送积分 - 已废弃，使用 products 表中的赠送积分
  giftPoint          Int?                       @default(0) @map("gift_point")
  /// 排序顺序
  sortOrder          Int                        @default(0)
  /// 状态：1-启用，0-禁用
  status             Int                        @default(1)
  /// 创建时间
  createdAt          DateTime?                  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt          DateTime?                  @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间
  deletedAt          DateTime?                  @map("deleted_at") @db.Timestamptz(6)
  levelModuleAccess  levelModuleAccess[]
  membershipBenefits membershipBenefits[]
  fromUpgradeRecords membershipUpgradeRecords[] @relation("FromLevel")
  toUpgradeRecords   membershipUpgradeRecords[] @relation("ToLevel")
  paymentOrders      paymentOrders[]
  products           products[]
  redemptionCodes    redemptionCodes[]
  userMemberships    userMemberships[]
  levelNodeAccesses  levelNodeAccess[]          @relation("levelNodeAccess")

  @@index([sortOrder], map: "idx_membership_levels_sort_order")
  @@index([status], map: "idx_membership_levels_status")
  @@index([deletedAt], map: "idx_membership_levels_deleted_at")
  @@map("membership_levels")
}

/// 权益表
model benefits {
  /// 权益ID，主键，自增
  id                 Int                  @id @default(autoincrement())
  /// 权益名称
  name               String               @db.VarChar(100)
  /// 权益描述
  description        String?              @db.VarChar(255)
  /// 单位类型
  unitType           Int                  @default(0) @map("unit_type")
  /// 最小单位
  minUnit            String?              @db.VarChar(10)
  /// 计量模式
  consumptionMode    Int                  @default(1) @map("consumption_mode")
  /// 创建时间
  createdAt          DateTime?            @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt          DateTime?            @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间
  deletedAt          DateTime?            @map("deleted_at") @db.Timestamptz(6)
  membershipBenefits membershipBenefits[]

  @@index([name], map: "idx_benefits_name")
  @@index([minUnit], map: "idx_benefits_min_unit")
  @@index([deletedAt], map: "idx_benefits_deleted_at")
  @@map("benefits")
}

/// 会员权益表
model membershipBenefits {
  /// 会员权益ID，主键，自增
  id                 Int              @id @default(autoincrement())
  /// 关联的会员级别ID，外键关联模会员级别表
  levelId            Int              @map("level_id")
  /// 关联的权益ID，外键关联权益表
  benefitId          Int              @map("benefit_id")
  /// 权益值
  benefitValue       Decimal          @map("benefit_value") @db.Decimal(15, 2)
  /// 单位
  unit               String?
  /// 周期性权益重置频率
  resetFrequencyUnit Int?             @map("reset_frequency_unit")
  /// 权益描述
  description        String?
  /// 状态：1-启用，0-禁用
  status             Int              @default(1)
  /// 创建时间
  createdAt          DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt          DateTime?        @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间
  deletedAt          DateTime?        @map("deleted_at") @db.Timestamptz(6)
  benefit            benefits         @relation(fields: [benefitId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  membershipLevel    membershipLevels @relation(fields: [levelId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([levelId, benefitId])
  @@index([levelId], map: "idx_membership_level_benefits_level_id")
  @@index([benefitId], map: "idx_membership_level_benefits_benefit_id")
  @@index([status], map: "idx_membership_level_benefits_status")
  @@index([deletedAt], map: "idx_membership_level_benefits_deleted_at")
  @@map("membership_benefits")
}

/// 用户权益表
model userBenefits {
  /// 用户权益ID，主键，自增
  id               Int                @id @default(autoincrement())
  /// 关联的用户ID，外键关联用户表
  userId           Int                @map("user_id")
  /// 资源ID,关联到user_benefits.id
  benefitId        Int                @map("benefit_id")
  /// 权益值
  benefitValue     Decimal            @map("benefit_value") @db.Decimal(15, 2)
  /// 单位
  unit             String?
  /// 已消耗量 
  consumedValue    Decimal            @default(0) @map("consumed_value") @db.Decimal(15, 2)
  /// 剩余量
  remainingValue   Decimal?           @default(0) @map("remaining_value") @db.Decimal(15, 2)
  /// 权益状态
  status           Int                @default(1) @map("status")
  /// 权益来源渠道
  sourceType       Int                @map("source_type")
  /// 权益来源ID，根据来源类型关联到不同的表
  sourceId         Int?               @map("source_id")
  /// 生效时间
  effectiveAt      DateTime?          @map("effective_at") @db.Timestamptz(6)
  /// 过期时间
  expiredAt        DateTime?          @map("expired_at") @db.Timestamptz(6)
  /// 备注
  remark           String?
  /// 创建时间
  createdAt        DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt        DateTime?          @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间
  deletedAt        DateTime?          @map("deleted_at") @db.Timestamptz(6)
  resourceUsageLog resourceUsageLog[]

  @@index([userId], map: "idx_user_benefits_user_id")
  @@index([benefitId], map: "idx_user_benefits_benefit_id")
  @@index([status], map: "idx_user_benefits_status")
  @@index([sourceType], map: "idx_user_benefits_source_type")
  @@index([effectiveAt], map: "idx_user_benefits_effective_at")
  @@index([expiredAt], map: "idx_user_benefits_expired_at")
  @@index([deletedAt], map: "idx_user_benefits_deleted_at")
  @@map("user_benefits")
}

/// 资源使用记录表
model resourceUsageLog {
  /// 资源使用记录ID，主键，自增
  id             Int          @id @default(autoincrement())
  /// 用户资源ID,关联到user_benefits.id
  userBenefitsId Int          @map("user_benefits_id")
  /// 资源使用量
  usageValue     Decimal      @map("usage_value") @db.Decimal(15, 2)
  /// 用量单位
  unit           String
  /// 状态
  status         Int          @default(1) @map("status")
  /// 备注
  remark         String?
  /// 创建时间
  createdAt      DateTime?    @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt      DateTime?    @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间
  deletedAt      DateTime?    @map("deleted_at") @db.Timestamptz(6)
  userBenefits   userBenefits @relation(fields: [userBenefitsId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userBenefitsId], map: "idx_resource_usage_log_user_benefits_id")
  @@index([deletedAt], map: "idx_resource_usage_log_deleted_at")
  @@map("resource_usage_log")
}

/// 用户会员信息表
model userMemberships {
  /// 会员ID，主键，自增
  id                                                                       Int                        @id @default(autoincrement())
  /// 关联的用户ID，外键关联用户表
  userId                                                                   Int                        @map("user_id")
  /// 关联的会员级别ID，外键关联会员级别表
  levelId                                                                  Int                        @map("level_id")
  /// 会员开始日期
  startDate                                                                DateTime                   @map("start_date") @db.Timestamptz(6)
  /// 会员到期日期
  endDate                                                                  DateTime                   @map("end_date") @db.Timestamptz(6)
  /// 是否自动续费
  autoRenew                                                                Boolean?                   @default(false) @map("auto_renew")
  /// 状态：1-有效，0-无效
  status                                                                   Int                        @default(1) @map("status")
  /// 会员来源类型：1-兑换码兑换，2-直接购买，3-管理员赠送，4-活动奖励，5-试用，6-注册赠送，7-推荐新用户注册赠送，8-会员升级，99-其他
  sourceType                                                               Int?                       @map("source_type")
  /// 会员来源ID，根据来源类型关联到不同的表
  sourceId                                                                 Int?                       @map("source_id")
  /// 创建时间
  createdAt                                                                DateTime?                  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt                                                                DateTime?                  @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为NULL表示未删除
  deletedAt                                                                DateTime?                  @map("deleted_at") @db.Timestamptz(6)
  /// 升级前的会员记录ID
  upgradedFromId                                                           Int?                       @map("upgraded_from_id")
  /// 升级后的会员记录ID
  upgradedToId                                                             Int?                       @map("upgraded_to_id")
  /// 升级支付的价格
  upgradePrice                                                             Decimal?                   @map("upgrade_price") @db.Decimal(10, 2)
  /// 是否为升级记录
  isUpgrade                                                                Boolean?                   @default(false) @map("is_upgrade")
  toUpgradeRecords                                                         membershipUpgradeRecords[] @relation("ToMembership")
  fromUpgradeRecords                                                       membershipUpgradeRecords[] @relation("FromMembership")
  redemptionRecords                                                        redemptionRecords[]
  upgradedFrom                                                             userMemberships?           @relation("MembershipUpgrade", fields: [upgradedFromId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_memberships_upgraded_from")
  upgradedTo                                                               userMemberships[]          @relation("MembershipUpgrade")
  user_memberships_user_memberships_upgraded_to_idTouser_memberships       userMemberships?           @relation("user_memberships_upgraded_to_idTouser_memberships", fields: [upgradedToId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_memberships_upgraded_to")
  other_user_memberships_user_memberships_upgraded_to_idTouser_memberships userMemberships[]          @relation("user_memberships_upgraded_to_idTouser_memberships")
  membershipLevel                                                          membershipLevels           @relation(fields: [levelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                                                                    users                      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([endDate], map: "idx_user_memberships_end_date")
  @@index([levelId], map: "idx_user_memberships_level_id")
  @@index([sourceType, sourceId], map: "idx_user_memberships_source")
  @@index([status], map: "idx_user_memberships_status")
  @@index([userId], map: "idx_user_memberships_user_id")
  @@index([deletedAt], map: "idx_user_memberships_deleted_at")
  @@index([upgradedFromId], map: "idx_user_memberships_upgraded_from_id")
  @@index([upgradedToId], map: "idx_user_memberships_upgraded_to_id")
  @@index([isUpgrade], map: "idx_user_memberships_is_upgrade")
  @@map("user_memberships")
}

/// 兑换码表
model redemptionCodes {
  /// 兑换码ID，主键，自增
  id                Int                 @id @default(autoincrement())
  /// 兑换码，唯一
  code              String              @unique @db.VarChar(50)
  /// 关联的会员级别ID，外键关联会员级别表
  levelId           Int                 @map("level_id")
  /// 兑换会员有效期天数
  duration          Int
  /// 状态：1-有效，2-已使用，3-已过期，4-已作废
  status            Int                 @default(1)
  /// 备注
  remark            String?             @db.VarChar(255)
  /// 赠送积分
  giftPoint         Int                 @default(0) @map("gift_point")
  /// 创建者ID，外键关联用户表
  createdBy         Int                 @map("created_by")
  /// 创建时间
  createdAt         DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt         DateTime?           @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为NULL表示未删除
  deletedAt         DateTime?           @map("deleted_at") @db.Timestamptz(6)
  users             users               @relation(fields: [createdBy], references: [id], onUpdate: NoAction)
  membershipLevel   membershipLevels    @relation(fields: [levelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  redemptionRecords redemptionRecords[]

  @@index([code], map: "idx_redemption_codes_code")
  @@index([createdBy], map: "idx_redemption_codes_created_by")
  @@index([levelId], map: "idx_redemption_codes_level_id")
  @@index([status], map: "idx_redemption_codes_status")
  @@index([deletedAt], map: "idx_redemption_codes_deleted_at")
  @@map("redemption_codes")
}

/// 会员兑换记录表
model redemptionRecords {
  /// 兑换记录ID，主键，自增
  id              Int              @id @default(autoincrement())
  /// 关联的兑换码ID，外键关联兑换码表
  codeId          Int              @map("code_id")
  /// 关联的用户ID，外键关联用户表
  userId          Int              @map("user_id")
  /// 兑换时间
  redeemedAt      DateTime         @default(now()) @map("redeemed_at") @db.Timestamptz(6)
  /// 兑换码过期时间
  expiresAt       DateTime         @map("expires_at") @db.Timestamptz(6)
  /// 状态：1-有效，2-已过期，3-已作废
  status          Int              @default(1)
  /// 关联的会员ID，外键关联会员表
  membershipId    Int?             @map("membership_id")
  /// 创建时间
  createdAt       DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt       DateTime?        @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为NULL表示未删除
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz(6)
  redemptionCodes redemptionCodes  @relation(fields: [codeId], references: [id], onUpdate: NoAction)
  userMemberships userMemberships? @relation(fields: [membershipId], references: [id], onUpdate: NoAction)
  users           users            @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([codeId], map: "idx_redemption_records_code_id")
  @@index([expiresAt], map: "idx_redemption_records_expires_at")
  @@index([membershipId], map: "idx_redemption_records_membership_id")
  @@index([status], map: "idx_redemption_records_status")
  @@index([userId], map: "idx_redemption_records_user_id")
  @@index([deletedAt], map: "idx_redemption_records_deleted_at")
  @@map("redemption_records")
}

/// 积分记录表
model pointRecords {
  /// 积分记录ID，主键，自增
  id                      Int                       @id @default(autoincrement())
  /// 关联的用户ID，外键关联用户表
  userId                  Int                       @map("user_id")
  /// 积分数量
  pointAmount             Int                       @map("point_amount")
  /// 已使用积分数量
  used                    Int                       @map("used")
  /// 剩余积分数量
  remaining               Int                       @map("remaining")
  /// 积分来源
  sourceType              Int                       @map("source_type")
  /// 积分来源ID，根据来源类型关联到不同的表
  sourceId                Int?                      @map("source_id")
  /// 用户会员记录ID
  userMembershipId        Int?                      @map("user_membership_id")
  /// 生效时间
  effectiveAt             DateTime                  @map("effective_at") @db.Timestamptz(6)
  /// 过期时间
  expiredAt               DateTime                  @map("expired_at") @db.Timestamptz(6)
  /// 结算时间
  settlementAt            DateTime?                 @map("settlement_at") @db.Timestamptz(6)
  /// 积分状态
  status                  Int                       @default(1) @map("status")
  /// 备注
  remark                  String?                   @map("remark")
  /// 创建时间
  createdAt               DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt               DateTime                  @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为NULL表示未删除
  deletedAt               DateTime?                 @map("deleted_at") @db.Timestamptz(6)
  pointConsumptionRecords pointConsumptionRecords[]
  users                   users                     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId], map: "idx_point_records_user_id")
  @@index([sourceType], map: "idx_point_records_source_type")
  @@index([sourceId], map: "idx_point_records_source_id")
  @@index([effectiveAt], map: "idx_point_records_effective_at")
  @@index([expiredAt], map: "idx_point_records_expired_at")
  @@index([settlementAt], map: "idx_point_records_settlement_at")
  @@index([deletedAt], map: "idx_point_records_deleted_at")
  @@map("point_records")
}

/// 积分消耗项目表
model pointConsumptionItems {
  /// 积分消耗项目ID，主键，自增
  id                      Int                       @id @default(autoincrement())
  /// 分组
  group                   String                    @db.VarChar(100)
  /// 积分消耗项目名称
  name                    String                    @db.VarChar(100)
  /// 积分消耗项目描述
  description             String?                   @db.VarChar(255)
  /// 项目计量单位
  unit                    String                    @db.VarChar(10)
  /// 积分消耗数量
  pointAmount             Int                       @map("point_amount")
  /// 积分消耗项目状态
  status                  Int                       @default(1)
  /// 创建时间
  createdAt               DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt               DateTime                  @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为NULL表示未删除
  deletedAt               DateTime?                 @map("deleted_at") @db.Timestamptz(6)
  /// 消耗折扣
  discount                Decimal?                  @default(1) @map("discount") @db.Decimal(3, 2)
  pointConsumptionRecords pointConsumptionRecords[]

  @@index([name], map: "idx_point_consumption_items_name")
  @@index([status], map: "idx_point_consumption_items_status")
  @@index([deletedAt], map: "idx_point_consumption_items_deleted_at")
  @@map("point_consumption_items")
}

/// 积分消耗记录表
model pointConsumptionRecords {
  /// 积分消耗记录ID，主键，自增
  id                    Int                   @id @default(autoincrement())
  /// 关联的用户ID，外键关联用户表
  userId                Int                   @map("user_id")
  /// 关联的积分记录ID，外键关联积分记录表
  pointRecordId         Int                   @map("point_record_id")
  /// 积分消耗项目ID，外键关联积分消耗项目表
  itemId                Int                   @map("item_id")
