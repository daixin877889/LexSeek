/// 案件表
model cases {
  /// 案件ID，主键，自增
  id            Int             @id @default(autoincrement())
  /// 案件标题
  title         String          @db.VarChar(500)
  /// 案件案件内容/描述内容
  content       String?
  /// 关联的用户ID，外键关联用户表
  userId        Int             @map("user_id")
  /// 关联的案件类型ID，外键关联案件类型表
  caseTypeId    Int             @map("case_type_id")
  /// 原告
  plaintiff     Json?           @map("plaintiff")
  /// 被告
  defendant     Json?           @map("defendant")
  /// 案件编号
  caseNumber    String?         @map("case_number") @db.VarChar(100)
  /// 案件状态：1-进行中，2-已完成，3-已关闭
  status        Int             @default(1)
  /// 完成时间
  completedAt   DateTime?       @map("completed_at") @db.Timestamptz(6)
  /// 关闭时间
  closedAt      DateTime?       @map("closed_at") @db.Timestamptz(6)
  /// 创建时间
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt     DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为NULL表示未删除
  deletedAt     DateTime?       @map("deleted_at") @db.Timestamptz(6)
  caseAnalyses  caseAnalyses[]
  caseMaterials caseMaterials[]
  caseType      caseType        @relation(fields: [caseTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         users           @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  caseSessions  caseSessions[]

  @@index([userId], map: "idx_cases_user_id")
  @@index([caseTypeId], map: "idx_cases_case_type_id")
  @@index([status], map: "idx_cases_status")
  @@index([deletedAt], map: "idx_cases_deleted_at")
}

/// 案件材料表
model caseMaterials {
  /// 材料ID，主键，自增
  id              Int         @id @default(autoincrement())
  /// 关联的用户ID，外键关联用户表
  userId          Int         @map("user_id")
  /// 关联的案件ID，外键关联案件表
  caseId          Int         @map("case_id")
  /// 材料名称
  name            String      @db.VarChar(255)
  /// 材料类型：1-案情材料，2-文档，3-图片，4-音频，5-视频
  type            Int         @db.SmallInt
  /// 材料内容，案情材料为用户输入内容，其他为解析后的内容
  content         String?
  /// OSS 文件ID，外键关联ossFiles表
  ossFileId       Int?        @map("oss_file_id")
  /// ASR 记录ID，外键关联asrRecords表
  asrRecordId     Int?        @map("asr_record_id")
  /// 材料分组
  materialGroup   String?     @map("material_group") @db.VarChar(100)
  /// 关键词
  keywords        Json?       @map("keywords")
  /// 摘要
  summary         String?     @map("summary")
  /// 向量存储的ID集合(仅text类型需要)
  vectorIds       Json?       @map("vector_ids")
  /// 最后嵌入时间(仅text类型需要)
  lastEmbeddingAt DateTime?   @map("last_embedding_at") @db.Timestamptz()
  /// 最后编辑时间
  lastEditAt      DateTime?   @map("last_edit_at") @db.Timestamptz()
  /// 创建时间
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt       DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为NULL表示未删除
  deletedAt       DateTime?   @map("deleted_at") @db.Timestamptz(6)
  asrRecords      asrRecords? @relation(fields: [asrRecordId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cases           cases       @relation(fields: [caseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ossFiles        ossFiles?   @relation(fields: [ossFileId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users       @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([caseId], map: "idx_case_materials_case_id")
  @@index([materialGroup], map: "idx_case_materials_material_group")
  @@index([type], map: "idx_case_materials_type")
  @@index([userId], map: "idx_case_materials_user_id")
  @@index([asrRecordId], map: "idx_case_materials_asr_record_id")
  @@index([lastEmbeddingAt], map: "idx_case_materials_last_embedding_at")
  @@index([lastEditAt], map: "idx_case_materials_last_edit_at")
  @@index([deletedAt], map: "idx_case_materials_deleted_at")
  @@map("case_materials")
}

