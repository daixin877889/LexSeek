  @@index([userId], map: "idx_asr_records_user_id")
  @@index([status], map: "idx_asr_records_status")
  @@index([audioUrl], map: "idx_asr_records_audio_url")
  @@index([lastEmbeddingAt], map: "idx_asr_records_last_embedding_at")
  @@index([lastEditAt], map: "idx_asr_records_last_edit_at")
  @@index([deletedAt], map: "idx_asr_records_deleted_at")
  @@map("asr_records")
}

