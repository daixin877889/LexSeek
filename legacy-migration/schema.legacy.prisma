/// 模型配置表
model models {
  /// 模型ID，主键，自增
  id                         Int               @id @default(autoincrement())
  /// 关联的模型提供商ID，外键关联模型提供商表
  providerId                 Int               @map("provider_id")
  /// 模型名称
  name                       String            @db.VarChar(100)
  /// 模型显示名称
  displayName                String            @map("display_name") @db.VarChar(100)
  /// 模型类型：chat-对话模型，embedding-嵌入模型
  modelType                  String            @map("model_type") @db.VarChar(20)
  /// 模型版本
  modelVersion               String?           @map("model_version") @db.VarChar(50)
  /// 上下文窗口
  contextWindow              Int?              @map("context_window")
  /// 是否默认：1-是，0-否
  isDefault                  Boolean?          @default(false) @map("is_default")
  /// 状态：1-启用，0-禁用
  status                     Int?              @default(1)
  /// 优先级，数字越小优先级越高，默认 10
  priority                   Int?              @default(10)
  /// 输入成本（每百万tokens）
  inputCostPerMillionTokens  Decimal?          @map("input_cost_per_million_tokens") @db.Decimal(12, 4)
  /// 输出成本（每百万tokens）
  outputCostPerMillionTokens Decimal?          @map("output_cost_per_million_tokens") @db.Decimal(12, 4)
  /// 创建时间
  createdAt                  DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt                  DateTime?         @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为NULL表示未删除
  deletedAt                  DateTime?         @map("deleted_at") @db.Timestamptz(6)
  analysisModules            analysisModules[]
  modelProviders             modelProviders    @relation(fields: [providerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  nodes                      nodes[]

  @@unique([providerId, name])
  @@map("models")
}

/// 节点表
model nodes {
  /// 节点ID，主键，自增
  id              Int               @id @default(autoincrement())
  /// 节点名称
  name            String            @db.VarChar(100)
  /// 节点标题
  title           String?           @db.VarChar(100)
  /// 节点描述
  description     String?           @db.VarChar(255)
  /// 节点类型
  type            String            @db.VarChar(100)
  /// 优先级，数字越小优先级越高，默认值100
  priority        Int               @default(100)
  /// 提示词列表，关联 prompts 表
  prompts         prompts[]         @relation("prompts")
  /// 模型ID
  modelId         Int
  /// 模型
  model           models            @relation(fields: [modelId], references: [id])
  /// 工具列表
  tools           Json?             @default("[]")
  /// 节点分组ID，关联 nodeGroup 表
  groupId         Int?              @map("group_id")
  /// 创建时间
  createdAt       DateTime?         @default(now()) @map("created_at") @db.Timestamptz()
  /// 最后更新时间
  updatedAt       DateTime?         @default(now()) @map("updated_at") @db.Timestamptz()
  /// 删除时间，为NULL表示未删除
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz()
  /// 节点分组
  nodeGroup       nodeGroup?        @relation("nodeGroup", fields: [groupId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  levelNodeAccess levelNodeAccess[] @relation("levelNodeAccess")

  @@index([name], map: "idx_node_name")
  @@index([type], map: "idx_node_type")
  @@index([groupId], map: "idx_node_group_id")
  @@index([deletedAt], map: "idx_node_deleted_at")
}

/// 节点分组
model nodeGroup {
  /// 节点分组ID，主键，自增
  id          Int       @id @default(autoincrement())
  /// 节点分组名称
  name        String    @db.VarChar(100)
  /// 节点分组描述
  description String?   @db.VarChar(255)
  /// 创建时间
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz()
  /// 最后更新时间
  updatedAt   DateTime? @default(now()) @map("updated_at") @db.Timestamptz()
  /// 删除时间，为NULL表示未删除
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()
  /// 节点分组与节点关联表
  nodes       nodes[]   @relation("nodeGroup")

  @@index([name], map: "idx_node_group_name")
  @@index([deletedAt], map: "idx_node_group_deleted_at")
  @@map("node_groups")
}

/// 会员级别与节点关联表
model levelNodeAccess {
  /// 会员级别节点权限ID，主键，自增
  id        Int              @id @default(autoincrement())
  /// 关联的会员级别ID，外键关联会员级别表
  levelId   Int              @map("level_id")
  /// 关联的节点ID，外键关联节点表
  nodeId    Int              @map("node_id")
  /// 创建时间
  createdAt DateTime?        @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt DateTime?        @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为NULL表示未删除
  deletedAt DateTime?        @map("deleted_at") @db.Timestamptz(6)
  level     membershipLevels @relation("levelNodeAccess", onDelete: NoAction, onUpdate: NoAction, fields: [levelId], references: [id])
  node      nodes            @relation("levelNodeAccess", fields: [nodeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([levelId], map: "idx_level_node_access_level_id")
  @@index([nodeId], map: "idx_level_node_access_node_id")
  @@index([deletedAt], map: "idx_level_node_access_deleted_at")
  @@map("level_node_access")
}

/// 提示词表
model prompts {
  /// 提示词ID，主键，自增
  id        Int       @id @default(autoincrement())
  /// 提示词名称
  name      String    @db.VarChar(100)
  /// 提示词标题
  title     String?   @db.VarChar(100)
  /// 提示词内容
  content   String    @db.Text()
  /// 变量列表
  variables Json?     @default("[]")
  /// 提示词版本
  version   String    @db.VarChar(100)
  /// 提示词类型：system-系统提示词，user-用户提示词，assistant-助手提示词，function-函数提示词
  type      String    @db.VarChar(100)
  /// 当前生效：1-生效，0-未生效
  status    Int       @default(0)
  /// 节点ID,关联 nodes 表
  nodeId    Int
  /// 节点
  node      nodes     @relation("prompts", fields: [nodeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /// 提示词创建时间
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz()
  /// 提示词最后更新时间
  updatedAt DateTime? @default(now()) @map("updated_at") @db.Timestamptz()
  /// 提示词删除时间，为NULL表示未删除
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz()

  /// 同 name 和 type 下只有一条生效的记录
  @@unique([name, type, status], map: "unique_prompt")
  /// 同 name 和 type 下 version 唯一
  @@unique([name, type, version], map: "unique_prompt_version")
  @@index([name], map: "idx_prompt_name")
  @@index([type], map: "idx_prompt_type")
  @@index([status], map: "idx_prompt_status")
}

/// 商品表
model products {
  /// 商品ID，主键，自增
  id                   Int               @id @default(autoincrement())
  /// 商品名称
  name                 String            @db.VarChar(100)
  /// 商品描述
  description          String?           @db.VarChar(500)
  /// 商品类型：1-会员，2-积分
  type                 Int
  /// 商品分类
  category             String?           @db.VarChar(50)
  /// 月度价格（会员专用）
  priceMonthly         Decimal?          @map("priceMonthly") @db.Decimal(10, 2)
  /// 年度价格（会员专用）
  priceYearly          Decimal?          @map("priceYearly") @db.Decimal(10, 2)
  /// 默认售卖时长（会员专用）：1-月，2-年
  defaultDuration      Int?              @map("default_duration")
  /// 单价（积分专用）
  unitPrice            Decimal?          @map("unitPrice") @db.Decimal(10, 2)
  /// 月度价格原价（会员专用）
  originalPriceMonthly Decimal?          @map("original_price_monthly") @db.Decimal(10, 2)
  /// 年度价格原价（会员专用）
  originalPriceYearly  Decimal?          @map("original_price_yearly") @db.Decimal(10, 2)
  /// 单价原价（积分专用）
  originalUnitPrice    Decimal?          @map("original_unit_price") @db.Decimal(10, 2)
  /// 最小购买数量
  minQuantity          Int?              @default(1)
  /// 最大购买数量
  maxQuantity          Int?
  /// 商品购买次数限制（0-不限制）
  purchaseLimit        Int?              @default(0) @map("purchase_limit")
  /// 关联会员级别ID（会员商品专用）
  levelId              Int?              @map("level_id")
  /// 积分数量（积分商品专用）
  pointAmount          Int?              @map("point_amount")
  /// 赠送积分
  giftPoint            Int?              @default(0) @map("gift_point")
  /// 排序
  sortOrder            Int               @default(0) @map("sort_order")
  /// 状态：0-下架，1-上架
  status               Int               @default(1)
  /// 创建时间
  createdAt            DateTime?         @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt            DateTime?         @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为NULL表示未删除
  deletedAt            DateTime?         @map("deleted_at") @db.Timestamptz(6)
  paymentOrders        paymentOrders[]
  membershipLevels     membershipLevels? @relation(fields: [levelId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([type], map: "idx_products_type")
  @@index([category], map: "idx_products_category")
  @@index([status], map: "idx_products_status")
  @@index([levelId], map: "idx_products_level_id")
  @@index([sortOrder], map: "idx_products_sort_order")
  @@index([deletedAt], map: "idx_products_deleted_at")
  @@map("products")
}

/// 支付订单表
model paymentOrders {
  /// 订单ID，主键，自增
  id                       Int                        @id @default(autoincrement())
  /// 订单号，唯一
  orderNo                  String                     @unique @map("order_no") @db.VarChar(50)
  /// 关联的用户ID，外键关联用户表
  userId                   Int                        @map("user_id")
  /// 关联的会员级别ID，外键关联会员级别表（兼容性保留）
  levelId                  Int?                       @map("level_id")
  /// 支付金额
  amount                   Decimal                    @db.Decimal(10, 2)
  /// 支付类型：1-微信支付，2-支付宝支付
  paymentType              Int                        @default(1) @map("payment_type")
  /// 支付方式：1-JSAPI支付，2-H5支付，3-APP支付
  paymentWay               Int                        @map("payment_way")
  /// 状态：0-未支付，1-已支付，2-已取消
  status                   Int                        @default(0)
  /// 预支付ID
  prepayId                 String?                    @map("prepay_id") @db.VarChar(100)
  /// 支付时间
  paymentTime              DateTime?                  @map("payment_time") @db.Timestamptz(6)
  /// 购买时长
  duration                 Int                        @default(12)
  /// 时间单位：1-月，2-年
  paymentUnit              Int                        @default(1) @map("payment_unit")
  /// 商品描述
  description              String?                    @db.VarChar(255)
  /// 创建时间
  createdAt                DateTime?                  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt                DateTime?                  @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为NULL表示未删除
  deletedAt                DateTime?                  @map("deleted_at") @db.Timestamptz(6)
  /// 关联的商品ID，外键关联商品表（新架构）
  productId                Int?                       @map("product_id")
  /// 购买数量
  quantity                 Int                        @default(1)
  membershipUpgradeRecords membershipUpgradeRecords[]
  membershipLevels         membershipLevels?          @relation(fields: [levelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  products                 products?                  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                    users                      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transactions             paymentTransactions[]

  @@index([orderNo], map: "idx_payment_orders_order_no")
  @@index([userId], map: "idx_payment_orders_user_id")
  @@index([productId], map: "idx_payment_orders_product_id")
  @@index([levelId], map: "idx_payment_orders_level_id")
  @@index([status], map: "idx_payment_orders_status")
  @@index([paymentType], map: "idx_payment_orders_payment_type")
  @@index([deletedAt], map: "idx_payment_orders_deleted_at")
  @@map("payment_orders")
}

/// 第三方支付交易记录表
model paymentTransactions {
  /// 交易ID，主键，自增
  id            Int           @id @default(autoincrement())
  /// 关联的订单ID
  orderId       Int           @map("order_id")
  /// 第三方支付交易号
  transactionId String        @map("transaction_id") @db.VarChar(100)
  /// 支付类型：1-微信支付，2-支付宝支付
  paymentType   Int           @map("payment_type")
  /// 支付方式：1-JSAPI支付，2-H5支付，3-APP支付
  paymentWay    Int           @map("payment_way")
  /// 支付金额
  amount        Decimal       @db.Decimal(10, 2)
  /// 交易状态：0-处理中，1-成功，2-失败
  status        Int           @default(0)
  /// 第三方支付状态描述
  tradeState    String?       @map("trade_state") @db.VarChar(50)
  /// 银行类型
  bankType      String?       @map("bank_type") @db.VarChar(50)
  /// 支付者信息，包括openid等
  payerInfo     Json?         @map("payer_info")
  /// 原始回调数据
  rawData       Json?         @map("raw_data")
  /// 通知时间
  notifyTime    DateTime?     @map("notify_time") @db.Timestamptz(6)
  /// 支付成功时间
  successTime   DateTime?     @map("success_time") @db.Timestamptz(6)
  /// 创建时间
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt     DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为NULL表示未删除
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamptz(6)
  paymentOrders paymentOrders @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([orderId], map: "idx_payment_transactions_order_id")
  @@index([transactionId], map: "idx_payment_transactions_transaction_id")
  @@index([paymentType], map: "idx_payment_transactions_payment_type")
  @@index([status], map: "idx_payment_transactions_status")
  @@index([notifyTime], map: "idx_payment_transactions_notify_time")
  @@map("payment_transactions")
}

/// OSS 文件表
model ossFiles {
  /// ID，主键，自增
  id                      Int                       @id @default(autoincrement())
  /// 关联的用户ID，外键关联用户表
  userId                  Int                       @map("user_id")
  /// 存储桶名称 
  bucketName              String                    @map("bucket_name") @db.VarChar(100)
  /// 文件名称
  fileName                String                    @map("file_name") @db.VarChar(255)
  /// 文件在 OSS 中的路径
  filePath                String?                   @map("file_path") @db.VarChar(500)
  /// 文件大小(字节)
  fileSize                Decimal                   @map("file_size") @db.Decimal(15, 2)
  /// 文件MIME类型
  fileType                String                    @map("file_type") @db.VarChar(100)
  /// 文件的md5值
  fileMd5                 String?                   @map("file_md5") @db.VarChar(32)
  /// 文件来源
  source                  String?
  /// 文件状态
  status                  Int                       @default(0) @map("status")
  /// 创建时间
  createdAt               DateTime?                 @default(now()) @map("created_at") @db.Timestamptz(6)
