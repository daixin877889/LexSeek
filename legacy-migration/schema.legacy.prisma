  caseSessions caseSessions @relation(fields: [sessionId], references: [sessionId], onDelete: NoAction, onUpdate: NoAction)

  @@index([messageType], map: "idx_case_session_messages_message_type")
  @@index([sessionId], map: "idx_case_session_messages_session_id")
  @@index([deletedAt], map: "idx_case_session_messages_deleted_at")
  @@map("case_session_messages")
}

/// 案件分析表
model caseAnalyses {
  /// 分析记录ID，主键，自增
  id              Int           @id @default(autoincrement())
  /// 关联的案件ID，外键关联案件表
  caseId          Int           @map("case_id")
  /// 分析类型，对应分析模块表的 name 字段
  analysisType    String        @map("analysis_type") @db.VarChar(50)
  /// 分析过程/中间数据
  analysisProcess String?       @map("analysis_process")
  /// 分析结果
  analysisResult  String?       @map("analysis_result")
  /// 是否激活：1-激活，0-非激活
  isActive        Int           @default(0) @map("is_active")
  /// 生成类型：1-自动，2-手动修改
  generationType  Int           @default(1) @map("generation_type")
  /// 案件分析创建者用户ID，外键关联用户表
  userId          Int           @map("user_id")
  /// 分析版本号
  version         Int
  /// 分析对应的 sessionId
  sessionId       String?       @map("session_id") @db.VarChar(100)
  /// 分析标题
  title           String?       @db.VarChar(100)
  /// 消耗的token数量
  usageToken      Int?          @map("usage_token")
  /// 大模型生成的消息ID
  messageId       String?       @map("message_id") @db.VarChar(100)
  /// 关键词
  keywords        Json?         @map("keywords")
  /// 摘要
  summary         String?       @map("summary")
  /// 向量存储的ID集合(仅text类型需要)
  vectorIds       Json?         @map("vector_ids")
  /// 最后嵌入时间(仅text类型需要)
  lastEmbeddingAt DateTime?     @map("last_embedding_at") @db.Timestamptz()
  /// 分析状态：0-未开始，1-分析中，2-分析完成，3-分析失败
  status          Int           @default(0)
  /// 开始分析时间
  startedAt       DateTime?     @map("started_at") @db.Timestamptz(6)
  /// 分析完成时间
  completedAt     DateTime?     @map("completed_at") @db.Timestamptz(6)
  /// 创建时间
  createdAt       DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt       DateTime?     @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为NULL表示未删除
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz(6)
  cases           cases         @relation(fields: [caseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users         @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  caseSessions    caseSessions? @relation(fields: [sessionId], references: [sessionId], onDelete: NoAction, onUpdate: NoAction)

  @@index([caseId], map: "idx_case_analyses_case_id")
  @@index([userId], map: "idx_case_analyses_user_id")
  @@index([deletedAt], map: "idx_case_analyses_deleted_at")
  @@map("case_analyses")
}

/// 会员级别与分析模块关联表
