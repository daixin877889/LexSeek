/// 文书模板表 - 存储可复用的法律文书模板
model documentTemplates {
  id           Int       @id @default(autoincrement())
  /// 模板名称
  name         String    @db.VarChar(200)
  /// 模板分类（如：起诉状、答辩状、合同等）
  category     String    @db.VarChar(100)
  /// 模板适用范围：global-全局，personal-个人
  scope        String    @default("global") @db.VarChar(20)
  /// 创建者用户ID（scope=personal 时必须存在）
  userId       Int?      @map("user_id")
  /// 关联的 OSS 文件ID（模板原始文件）
  ossFileId    Int       @map("oss_file_id")
  /// 占位符列表（JSON 数组，扫描自模板文件）
  placeholders Json      @default("[]") @db.JsonB
  /// 模板描述
  description  String?   @db.VarChar(500)
  /// 排序优先级，数字越小越靠前
  priority     Int       @default(100)
  /// 状态：1-启用，0-禁用
  status       Int       @default(1)
  /// 创建时间
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为 NULL 表示未删除
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  /// 创建者用户（scope=personal 时存在）
  user   users?           @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /// 关联的文书草稿
  drafts documentDrafts[]

  @@index([scope, userId], map: "idx_doc_templates_scope_user")
  @@index([category], map: "idx_doc_templates_category")
  @@index([status, deletedAt], map: "idx_doc_templates_status")
  @@map("document_templates")
}

/// 文书草稿表 - 存储用户基于模板生成的文书草稿
model documentDrafts {
  id              Int       @id @default(autoincrement())
  /// 草稿所有者用户ID
  userId          Int       @map("user_id")
  /// 关联的案件ID（可选，文书生成时可绑定具体案件）
  caseId          Int?      @map("case_id")
  /// 会话唯一标识，用于 LangGraph thread_id
  sessionId       String    @map("session_id") @db.VarChar(100)
  /// 关联的模板ID（自由文书 mode=freeform 时为 null）
  templateId      Int?      @map("template_id")
  /// 文书模式：template-模板文书 / freeform-自由文书（无模板，正文直接存 content）
  mode            String    @default("template") @db.VarChar(20)
  /// 占位符填充值（JSON 对象，mode=template 时使用）
  values          Json      @default("{}") @db.JsonB
  /// 自由文书正文（Markdown，mode=freeform 时使用；模板文书为 null）
  content         String?   @db.Text
  /// 来源素材引用（JSON，记录引用的材料 ID 等）
  sourceRef       Json?     @map("source_ref") @db.JsonB
  /// 扩展元数据（JSON）
  metadata        Json?     @db.JsonB
  /// 生成结果文件 OSS ID（导出后填入）
  outputFileId    Int?      @map("output_file_id")
  /// 草稿状态：drafting-草稿中，reviewing-审核中，completed-已完成
  status          String    @default("drafting") @db.VarChar(30)
  /// 文书标题（创建时默认 "模板名-YYMMDD"；AI 仅在 titleOverridden=false 时覆盖）
  title           String    @default("") @db.VarChar(200)
  /// 用户是否手动修改过标题；为 true 后 AI 不再覆盖
  titleOverridden Boolean   @default(false) @map("title_overridden")
  /// 已发放版本号单调计数器（只增不减；物理删除版本不回收号）
  maxVersionNo    Int       @default(0) @map("max_version_no")
  /// 创建时间
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为 NULL 表示未删除
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  /// 草稿所有者
  user      users                    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /// 关联的案件（可选）
  case      cases?                   @relation(fields: [caseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /// 关联的模板（mode=freeform 自由文书时为 null）
  template  documentTemplates?       @relation(fields: [templateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /// 关联的素材（文书生成时上传的附件材料）
  materials caseMaterials[]
  /// AI 历史快照与覆盖前自动备份
  snapshots documentDraftSnapshots[]
  /// 用户主动保存的版本
  versions  documentDraftVersions[]

  @@unique([sessionId], map: "idx_doc_drafts_session")
  @@index([userId, deletedAt], map: "idx_doc_drafts_user")
  @@index([caseId], map: "idx_doc_drafts_case")
  @@index([templateId], map: "idx_doc_drafts_template")
  @@map("document_drafts")
}

/// 文书草稿快照表 - AI 重跑 / 覆盖工作区前的自动历史记录（10 条共享上限）
model documentDraftSnapshots {
  id        Int      @id @default(autoincrement())
  draftId   Int      @map("draft_id")
  /// 来源：ai-extract（AI 生成后落盘）、workspace-backup（覆盖工作区前自动备份）
  source    String   @db.VarChar(30)
  /// 快照时的 values 全量拷贝（mode=template 时使用）
  values    Json     @default("{}") @db.JsonB
  /// 快照时的自由文书正文（mode=freeform 时使用）
  content   String?  @db.Text
  /// AI 本轮产出的推断标题（可空）
  aiTitle   String?  @map("ai_title") @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  draft documentDrafts @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId, createdAt(sort: Desc)], map: "idx_doc_snapshots_draft_time")
  @@map("document_draft_snapshots")
}

/// 文书草稿版本表 - 用户主动保存的里程碑，只读、永久保留、无上限
model documentDraftVersions {
  id        Int      @id @default(autoincrement())
  draftId   Int      @map("draft_id")
  /// 版本序号，1 基；同 draftId 内自增，删除不回收
  versionNo Int      @map("version_no")
  /// 用户命名（默认建议"第 X 版"由前端带出）
  name      String   @db.VarChar(100)
  /// 版本的 values 全量拷贝（mode=template 时使用）
  values    Json     @default("{}") @db.JsonB
  /// 版本的自由文书正文快照（mode=freeform 时使用）
  content   String?  @db.Text
  /// 版本创建时 draft 的标题（用于导出文件名 / 历史显示）
  titleAt   String   @map("title_at") @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  draft documentDrafts @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@unique([draftId, versionNo], map: "idx_doc_versions_draft_no")
  @@index([draftId, createdAt(sort: Desc)], map: "idx_doc_versions_draft_time")
  @@map("document_draft_versions")
}
