/// OSS 文件表
model ossFiles {
  /// ID，主键，自增
  id               Int       @id @default(autoincrement())
  /// 关联的用户ID，外键关联用户表
  userId           Int       @map("user_id")
  /// 存储桶名称 
  bucketName       String    @map("bucket_name") @db.VarChar(100)
  /// 文件名称
  fileName         String    @map("file_name") @db.VarChar(255)
  /// 文件在 OSS 中的路径
  filePath         String?   @map("file_path") @db.VarChar(500)
  /// 文件大小(字节)
  fileSize         Decimal   @map("file_size") @db.Decimal(15, 2)
  /// 文件MIME类型
  fileType         String    @map("file_type") @db.VarChar(100)
  /// 文件的md5值
  fileMd5          String?   @map("file_md5") @db.VarChar(32)
  /// 文件来源
  source           String?
  /// 文件状态
  status           Int       @default(0) @map("status")
  /// 是否加密
  encrypted        Boolean   @default(false) @map("encrypted")
  /// 原始 MIME 类型（加密文件需要）
  originalMimeType String?   @map("original_mime_type") @db.VarChar(100)
  /// 创建时间
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 最后更新时间
  updatedAt        DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)
  /// 删除时间，为NULL表示未删除
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  // 示范案例克隆场景的去重联合键：同一用户下同一 OSS 对象（bucket+path）只能有一行
  // 显式指定约束名，便于排查 P2002 错误时通过 err.meta.target 识别冲突来源
  @@unique([userId, bucketName, filePath], map: "idx_oss_files_user_bucket_path")
  @@index([userId], map: "idx_oss_files_user_id")
  @@index([bucketName], map: "idx_oss_files_bucket_name")
  @@index([fileName], map: "idx_oss_files_file_name")
  @@index([fileType], map: "idx_oss_files_file_type")
  @@index([status], map: "idx_oss_files_status")
  @@index([deletedAt], map: "idx_oss_files_deleted_at")
  @@index([encrypted], map: "idx_oss_files_encrypted")
  @@map("oss_files")
}
