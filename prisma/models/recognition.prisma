/// 文档识别记录表 - 存储 PDF 转换结果
model docRecognitionRecords {
    /// 记录ID，主键，自增
    id              Int       @id @default(autoincrement())
    /// 关联的用户ID
    userId          Int       @map("user_id")
    /// 关联的 OSS 文件ID
    ossFileId       Int       @map("oss_file_id")
    /// 识别状态：0-待处理，1-处理中，2-成功，3-失败
    status          Int       @default(0)
    /// HTML 内容
    htmlContent     String?   @map("html_content") @db.Text
    /// Markdown 内容
    markdownContent String?   @map("markdown_content") @db.Text
    /// 关键词（JSON 数组）
    keywords        Json?     @default("[]")
    /// 摘要
    summary         String?   @db.Text
    /// 向量存储 ID 集合（JSON 数组）
    vectorIds       Json?     @default("[]") @map("vector_ids")
    /// 最后嵌入时间
    lastEmbeddingAt DateTime? @map("last_embedding_at") @db.Timestamptz(6)
    /// 最后编辑时间
    lastEditAt      DateTime? @map("last_edit_at") @db.Timestamptz(6)
    /// 创建时间
    createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
    /// 最后更新时间
    updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
    /// 删除时间，为 NULL 表示未删除
    deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

    /// 关联的用户
    user users @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

    @@index([userId], map: "idx_doc_recognition_records_user_id")
    @@index([ossFileId], map: "idx_doc_recognition_records_oss_file_id")
    @@index([status], map: "idx_doc_recognition_records_status")
    @@index([deletedAt], map: "idx_doc_recognition_records_deleted_at")
    @@map("doc_recognition_records")
}

